{
  "extends": "@backstage/cli/config/tsconfig.json",
  "include": [
    "playwright.config.ts",
    "packages/*/src",
    "packages/*/config.d.ts",
    "plugins/*/src",
    "plugins/*/config.d.ts",
    "plugins/*/dev",
    "plugins/*/migrations"
  ],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "outDir": "dist-types",
    "rootDir": ".",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@backstage/plugin-tech-radar/alpha": [
        "node_modules/@backstage/plugin-tech-radar/dist/alpha.d.ts"
      ]
    }
  }
}
